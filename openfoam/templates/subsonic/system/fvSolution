FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-8;
        relTol          0.05;
    }

    "(U|e|h|k|omega)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-8;
        relTol          0.1;
        minIter         1;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 0;

    // Non-transonic compressible SIMPLE: at Ma ~0.7 the rho-interpolated
    // pressure flux is far more robust than transonic mode. pMin/pMaxFactor
    // clamp p (hence rho = psi*p) so a bad base-region cell cannot run away.
    pMinFactor      0.1;
    pMaxFactor      2;

    residualControl
    {
        p           1e-4;
        U           1e-4;
        e           1e-4;
        "(k|omega)" 1e-4;
    }
}

relaxationFactors
{
    fields
    {
        p           0.7;
        rho         0.01;
    }
    equations
    {
        U           0.3;
        e           0.7;
        "(k|omega)" 0.7;
    }
}


