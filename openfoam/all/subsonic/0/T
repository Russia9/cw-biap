FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}
#include "../constant/freestreamProperties"
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform $TInf;

boundaryField
{
    "(inlet|outlet|farfield)"
    {
        type            freestream;
        freestreamValue uniform $TInf;
        value           uniform $TInf;
    }
    model
    {
        type            zeroGradient;       // adiabatic wall
    }
}


