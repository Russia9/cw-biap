FoamFile { version 2.0; format ascii; class dictionary; object surfaceFeatureExtractDict; }

// Extract sharp edges of the rocket surface -> constant/triSurface/model.eMesh,
// referenced by snappyHexMeshDict features{}.  model.stl is already in metres.
model.stl
{
    scale               1;
    extractionMethod    extractFromSurface;
    extractFromSurfaceCoeffs { includedAngle 150; }
    writeObj yes;
}


