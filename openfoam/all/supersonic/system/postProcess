// Function-object definitions included into controlDict's functions {} block.
// Freestream values + coefficient references are included at the controlDict
// root (constant/freestreamProperties) and referenced here as $macros.

// HiSA is a true compressible solver with a live rho field and real pressure in
// Pa, so forceCoeffs integrates the real forces (rho = rho) and normalises by
// the freestream dynamic pressure 0.5*rhoInf*magUInf^2*Aref.  Aref/lRef are the
// fixed part="all" references (frontal area + body length) so the coefficients
// are comparable across all parts and Mach numbers.
forceCoeffs
{
    type            forceCoeffs;
    libs            (forces);
    patches         (model);
    rho             rho;            // compressible: integrate against live density
    rhoInf          $rhoInf;        // freestream density for the q normalisation
    magUInf         $magUInf;
    Aref            $Aref;
    lRef            $lRef;
    dragDir         $dragDir;
    liftDir         $liftDir;
    pitchAxis       $pitchAxis;
    CofR            $CofR;
    writeControl    timeStep;
    writeInterval   1;
    log             yes;
}

MachNo
{
    type            MachNo;
    libs            (fieldFunctionObjects);
    writeControl    writeTime;
}

gradRho
{
    type         grad;
    libs         (fieldFunctionObjects);
    field        rho;
    result       gradRho;
    writeControl writeTime;
}
magGradRho
{
    type         mag;
    libs         (fieldFunctionObjects);
    field        gradRho;
    result       schlieren;
    writeControl writeTime;
}

pressureCoeff
{
    type            pressure;
    libs            (fieldFunctionObjects);
    mode            staticCoeff;
    result          Cp;
    rhoInf          $rhoInf;
    pInf            $pInf;
    UInf            $UInf;
    writeControl    writeTime;
}

yPlus
{
    type         yPlus;
    libs         (fieldFunctionObjects);
    writeControl writeTime;
    log yes;
}

wallShearStress
{
    type         wallShearStress;
    libs         (fieldFunctionObjects);
    patches      (model);
    writeControl writeTime;
}
