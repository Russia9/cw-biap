FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
#include "../constant/freestreamProperties"
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform $pInf;

boundaryField
{
    "(inlet|outlet|farfield)"
    {
        type            characteristicFarfieldPressure;
        U               $UInf;
        p               $pInf;
        T               $TInf;
        value           $internalField;
    }
    fuselage
    {
        type            characteristicWallPressure;
        value           $internalField;
    }
    stabilizers
    {
        type            characteristicWallPressure;
        value           $internalField;
    }
}


