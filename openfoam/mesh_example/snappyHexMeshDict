FoamFile { version 2.0; format ascii; class dictionary; object snappyHexMeshDict; }

// Rocket external-aero mesh.  ONE surface, constant/triSurface/model.stl (the
// cleaned PART="all" rocket, in METRES -> scale 1), meshed as a single wall
// patch "model".  Refinement regions and layers are first estimates sized to
// the rocket (L = 18.29 m, D_max = 1.58 m, body radius 0.79 m, x in [0,18.29]);
// TUNE levels/extents against checkMesh to keep the total under maxGlobalCells
// (3.0M) and the layers within y+ 300-350.

castellatedMesh true;
snap            true;
addLayers       true;

geometry
{
    model.stl
    {
        type triSurfaceMesh;
        scale 1;              // model.stl is already in metres
        name model;
    }

    // Broad refinement from upstream of the nose through the near wake.
    broadCylinder
    {
        type searchableCylinder;
        point1 (-8.0 0.0 0.0);
        point2 (55.0 0.0 0.0);
        radius 6.0;
    }

    // Stronger refinement hugging the body and immediate wake.
    nearBodyCylinder
    {
        type searchableCylinder;
        point1 (-3.0 0.0 0.0);
        point2 (30.0 0.0 0.0);
        radius 2.5;
    }

    // Tight band just outside the body envelope (max radius 0.785 m).
    closeBodyCylinder
    {
        type searchableCylinder;
        point1 (-1.0 0.0 0.0);
        point2 (21.0 0.0 0.0);
        radius 1.3;
    }
};

castellatedMeshControls
{
    maxGlobalCells   3000000;
    maxLocalCells    300000;
    minRefinementCells 8;
    maxLoadUnbalance 0.10;
    nCellsBetweenLevels 3;
    resolveFeatureAngle 30;

    features
    (
        { file "model.eMesh"; level 4; }
    );

    refinementSurfaces
    {
        model
        {
            level (3 4);
            patchInfo { type wall; }
        }
    }

    refinementRegions
    {
        broadCylinder    { mode inside; levels ((1E15 1)); }
        nearBodyCylinder { mode inside; levels ((1E15 2)); }
        closeBodyCylinder{ mode inside; levels ((1E15 3)); }
    }

    // Upstream of the nose, off the axis -> unambiguously in the fluid.
    locationInMesh (-50.0 1.0 1.0);
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch    3;
    tolerance       2.0;
    nSolveIter      55;
    nRelaxIter      6;
    nFeatureSnapIter 15;
    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeatureSnap false;
}

addLayersControls
{
    meshShrinker displacementMedialAxis;

    // Absolute sizing for a wall-function (high-Re) boundary layer.
    // firstLayerThickness is the wall-adjacent cell height; ~3 mm puts y+ near
    // 300 at mid-body (U=102 m/s, Re_L ~ 1.3e8, flat-plate Cf).  Re-read the
    // yPlus function object after a short run and scale this to land in 300-350.
    relativeSizes false;
    layers
    {
        model { nSurfaceLayers 6; }
    }
    expansionRatio           1.2;
    firstLayerThickness      3.0e-3;

    maxFaceThicknessRatio    10.0;
    minThickness             1e-4;
    nSmoothThickness         5;
    nSmoothNormals           3;
    nSmoothSurfaceNormals    3;
    nGrow                    0;
    nBufferCellsNoExtrude    1;
    featureAngle             160;
    slipFeatureAngle         75;
    nRelaxIter               8;
    nRelaxedIter             25;
    nLayerIter               30;

    minMedialAxisAngle       80;
    maxThicknessToMedialRatio 0.6;
    nMedialAxisIter          10;
}

meshQualityControls
{
    maxNonOrtho          75;
    maxBoundarySkewness  20;
    maxInternalSkewness  8;
    maxConcave           80;
    minFlatness          0.5;
    minVol               1e-15;
    minTetQuality        -1e30;
    minArea              -1;
    minTwist             -1;
    minDeterminant       1e-9;
    minFaceWeight        -1;
    minVolRatio          -1;
    minTriangleTwist     -1;
    nSmoothScale         4;
    errorReduction       0.45;

    relaxed
    {
        maxNonOrtho          80;
        minDeterminant       1e-12;
        minFaceWeight        -1;
        minTetQuality        -1e30;
        minTwist             -1;
        minVolRatio          -1;
    }
}

writeFlags
(
    scalarLevels
);

mergeTolerance 1e-8;
