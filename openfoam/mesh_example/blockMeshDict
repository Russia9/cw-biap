FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Cylindrical O-grid background (same 5-block topology as the arc case), but in
// METRES (scale 1) because rocket.stl is exported in metres.  Flow is +x; the
// model.stl nose tip is at x = 0 and the aft-most plane at x = L = 18.29 m.
//
// Domain (L = 18.29 m = full PART="all" length):
//   inlet   x = -5L  = -91.45 m   (5L upstream of the nose)
//   outlet  x = L+10L = 201.19 m  (10L downstream of the aft-most plane)
//   radius  R = 5L   =  91.45 m   (cylindrical farfield)
//   O-grid core half-width a = 4.0 m  (the body, max radius 0.79 m, sits inside)
//   outer vertex coordinate c = R/sqrt(2) = 64.666 m
//
// Grading concentrates cells near the body: an axial fine band over x in
// [-10, 45] m (nose -> wake) and radial grading from ~0.5 m at the core to
// ~15 m at the farfield.  Divisions below give ~370k background cells; snappy
// then refines toward the surface.  TUNE Nx/Nc/Nr and the grading to keep the
// post-snappy total under maxGlobalCells (3.0M) once model.stl is meshed.

scale   1;

vertices
(
    // inlet plane (x = -91.45 m)
    (-91.45  -4.0000  -4.0000)   //  0  inner SW
    (-91.45   4.0000  -4.0000)   //  1  inner SE
    (-91.45   4.0000   4.0000)   //  2  inner NE
    (-91.45  -4.0000   4.0000)   //  3  inner NW
    (-91.45 -64.666 -64.666)     //  4  outer SW
    (-91.45  64.666 -64.666)     //  5  outer SE
    (-91.45  64.666  64.666)     //  6  outer NE
    (-91.45 -64.666  64.666)     //  7  outer NW

    // outlet plane (x = 201.19 m)
    (201.19  -4.0000  -4.0000)   //  8  inner SW
    (201.19   4.0000  -4.0000)   //  9  inner SE
    (201.19   4.0000   4.0000)   // 10  inner NE
    (201.19  -4.0000   4.0000)   // 11  inner NW
    (201.19 -64.666 -64.666)     // 12  outer SW
    (201.19  64.666 -64.666)     // 13  outer SE
    (201.19  64.666  64.666)     // 14  outer NE
    (201.19 -64.666  64.666)     // 15  outer NW
);

// Axial multi-grading (identical on every block; shared x-edges).
//   zone A  inlet -> x=-10   : 30  cells, coarse -> fine  (ratio 0.1)
//   zone B  x=-10 -> x=45    : 110 cells, ~uniform 0.5 m  (ratio 1)
//   zone C  x=45  -> outlet  : 45  cells, fine  -> coarse (ratio 16)
// Total Nx = 185.  Length/cell fractions of the 292.64 m span:
xGrading
(
    (0.278352 0.162162 0.1)
    (0.187951 0.594595 1)
    (0.533697 0.243243 16)
);

// Radial grading (outer blocks): last/first cell ratio.  G grows cells from the
// core (~0.5 m) outward to the farfield (~15 m); 1/G is the same edge traversed
// outer->inner.  Nr = 20.
// G    = 30
// invG = 0.033333

blocks
(
    // core (square prism around the body) -- uniform transverse, no radial grading
    hex (0 8 9 1 3 11 10 2) (185 20 20)
    simpleGrading ( $xGrading 1 1 )

    // -Z outer block : radial edge runs outer->inner -> invG
    hex (4 12 13 5 0 8 9 1) (185 20 20)
    simpleGrading ( $xGrading 1 0.033333 )

    // +Y outer block : radial edge runs inner->outer -> G
    hex (1 9 13 5 2 10 14 6) (185 20 20)
    simpleGrading ( $xGrading 30 1 )

    // +Z outer block : radial edge runs inner->outer -> G
    hex (3 11 10 2 7 15 14 6) (185 20 20)
    simpleGrading ( $xGrading 1 30 )

    // -Y outer block : radial edge runs outer->inner -> invG
    hex (4 12 8 0 7 15 11 3) (185 20 20)
    simpleGrading ( $xGrading 0.033333 1 )
);

edges
(
    arc 7 6   (-91.45   0.000  91.45)
    arc 6 5   (-91.45  91.45   0.000)
    arc 4 5   (-91.45   0.000 -91.45)
    arc 4 7   (-91.45 -91.45   0.000)

    arc 15 14 (201.19   0.000  91.45)
    arc 14 13 (201.19  91.45   0.000)
    arc 12 13 (201.19   0.000 -91.45)
    arc 12 15 (201.19 -91.45   0.000)
);

boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 3 2 1)
            (4 0 1 5)
            (1 2 6 5)
            (3 7 6 2)
            (4 7 3 0)
        );
    }
    outlet
    {
        type patch;
        faces
        (
            (8 9 10 11)
            (12 13 9 8)
            (9 13 14 10)
            (11 10 14 15)
            (12 8 11 15)
        );
    }
    farfield
    {
        type patch;
        faces
        (
            (7 15 14 6)
            (6 14 13 5)
            (4 5 13 12)
            (4 12 15 7)
        );
    }
);

mergePatchPairs();


